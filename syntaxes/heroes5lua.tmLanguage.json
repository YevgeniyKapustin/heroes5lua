{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Heroes5Lua",
    "scopeName": "source.heroes5lua",

    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#numbers" },
		{
			"name": "support.function.heroes5lua",
			"match": "\\b[A-Z][a-z][a-zA-Z0-9_]*\\b"
		}
    ],

    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.heroes5lua",
                    "match": "--.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.heroes5lua",
                    "match": "\\b(if|for|while|return|end|function)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.heroes5lua",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.heroes5lua",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.heroes5lua",
            "match": "\\b\\d+\\b"
        }
    }
}
